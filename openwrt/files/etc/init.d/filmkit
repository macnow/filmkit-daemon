#!/bin/sh /etc/rc.common
# filmkit-daemon OpenWRT init script
# Install: cp filmkit /etc/init.d/filmkit && chmod +x /etc/init.d/filmkit && /etc/init.d/filmkit enable

START=99
STOP=10
USE_PROCD=1

DAEMON=/usr/bin/filmkit-daemon
FRONTEND=/www/filmkit
PORT=8765
PIDFILE=/var/run/filmkit.pid
LOGFILE=/var/log/filmkit.log

start_service() {
    procd_open_instance
    procd_set_param command "$DAEMON" \
        -port "$PORT" \
        -frontend "$FRONTEND"
    procd_set_param stdout 1
    procd_set_param stderr 1
    procd_set_param pidfile "$PIDFILE"
    procd_set_param respawn 3600 5 0   # respawn: threshold delay max_fail
    procd_close_instance
}

stop_service() {
    rm -f "$PIDFILE"
}

service_triggers() {
    procd_add_reload_trigger "filmkit"
}
